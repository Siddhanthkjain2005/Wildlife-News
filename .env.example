APP_NAME="Wildlife Live Poaching News System"
DATABASE_URL="sqlite:///./data/news.db"
EXCEL_PATH="./data/wildlife_poaching_news.xlsx"
SYNC_INTERVAL_MINUTES=3
TODAY_ONLY=false
APP_TIMEZONE="Asia/Kolkata"
START_FROM_DATE="2026-04-19"
MAX_ARTICLES_PER_QUERY=80
MAX_QUERIES_PER_LANGUAGE=10
PROVIDER_PARALLEL_WORKERS=10
AI_THRESHOLD=0.48
INDIA_THRESHOLD=0.40
INDIA_ONLY=true
STRICT_AI_MODE=false
MODEL_NAME="MoritzLaurer/mDeBERTa-v3-base-mnli-xnli"
PERSON_NER_ENABLED=true
PERSON_NER_MODEL_NAME="Babelscape/wikineural-multilingual-ner"
PERSON_NER_MIN_SCORE=0.65
ARTICLE_ENRICHMENT_ENABLED=true
ARTICLE_ENRICHMENT_MIN_CHARS=200
ARTICLE_ENRICHMENT_MAX_CHARS=4000
REQUEST_TIMEOUT_SECONDS=25
ARTICLE_FETCH_TIMEOUT_SECONDS=15
PROVIDER_MIN_REQUEST_INTERVAL_SECONDS=0.8
PROVIDER_RATE_LIMIT_COOLDOWN_SECONDS=600
SYNC_SCHEDULER_JITTER_SECONDS=15
RISK_ALERT_THRESHOLD=75
DEDUPE_TITLE_SIMILARITY_THRESHOLD=0.90
DEDUPE_SEMANTIC_SIMILARITY_THRESHOLD=0.84
DEDUPE_EMBEDDING_MODEL_NAME="sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"
ENABLED_PROVIDERS="google_rss,bing_rss,gdelt,duckduckgo,indian_media_rss,newsapi,gnews,mediastack,newsdata,currents,thenewsapi,worldnewsapi,eventregistry,newscatcher,reddit_osint,ngo_feeds,x_adapter"
SUPPORTED_LANGUAGES="en,hi,kn,ta,te,ml,bn,mr,gu,pa,ur,or,as"
NEWSAPI_KEY=""
GNEWS_API_KEY=""
MEDIASTACK_API_KEY=""
NEWSDATA_API_KEY=
CURRENTS_API_KEY=
THENEWSAPI_KEY=
WORLDNEWSAPI_KEY=""
# EventRegistry — free 200 req/day: https://eventregistry.org/register
EVENTREGISTRY_API_KEY=""
# NewsCatcher — free 1000 calls/month: https://www.newscatcherapi.com/free-news-api
NEWSCATCHER_API_KEY=""
ALERTS_ENABLED=false
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
ALERT_EMAIL_TO=""
ALERT_DISPATCH_INTERVAL_SECONDS=60
LOG_DIR="./logs"
FRONTEND_ORIGIN="https://wildlife-news.vercel.app,https://*.vercel.app"
ADMIN_TOKEN=""
ADMIN_API_KEY=""
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""
ADMIN_PASSWORD_HASH=""
ADMIN_SESSION_MINUTES=480
API_RATE_LIMIT_PER_MINUTE=180
LOGIN_RATE_LIMIT_PER_MINUTE=10
SYNC_RATE_LIMIT_PER_MINUTE=8
CACHE_TTL_SECONDS=30
BACKUP_INTERVAL_MINUTES=60
BACKUPS_DIR="./data/backups"
