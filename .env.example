APP_NAME="Wildlife Live Poaching News System"
DATABASE_URL="sqlite:///./data/news.db"
EXCEL_PATH="./data/wildlife_poaching_news.xlsx"
SYNC_INTERVAL_MINUTES=3
TODAY_ONLY=false
APP_TIMEZONE="Asia/Kolkata"
START_FROM_DATE="2026-04-19"
MAX_ARTICLES_PER_QUERY=60
MAX_QUERIES_PER_LANGUAGE=8
PROVIDER_PARALLEL_WORKERS=8
AI_THRESHOLD=0.50
INDIA_THRESHOLD=0.45
INDIA_ONLY=true
MODEL_NAME="MoritzLaurer/mDeBERTa-v3-base-mnli-xnli"
PERSON_NER_ENABLED=true
PERSON_NER_MODEL_NAME="Babelscape/wikineural-multilingual-ner"
PERSON_NER_MIN_SCORE=0.70
REQUEST_TIMEOUT_SECONDS=25
PROVIDER_MIN_REQUEST_INTERVAL_SECONDS=1.0
PROVIDER_RATE_LIMIT_COOLDOWN_SECONDS=600
SYNC_SCHEDULER_JITTER_SECONDS=20
RISK_ALERT_THRESHOLD=80
DEDUPE_TITLE_SIMILARITY_THRESHOLD=0.92
DEDUPE_SEMANTIC_SIMILARITY_THRESHOLD=0.86
DEDUPE_EMBEDDING_MODEL_NAME="sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"
ENABLED_PROVIDERS="google_rss,bing_rss,gdelt,newsapi,gnews,mediastack,newsdata,reddit_osint,ngo_feeds,x_adapter"
SUPPORTED_LANGUAGES="en,hi,kn,ta,te,ml,bn,mr,gu,pa,ur,or,as"
NEWSAPI_KEY=""
GNEWS_API_KEY=""
MEDIASTACK_API_KEY=""
NEWSDATA_API_KEY=""
ALERTS_ENABLED=false
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
ALERT_EMAIL_TO=""
ALERT_DISPATCH_INTERVAL_SECONDS=60
LOG_DIR="./logs"
FRONTEND_ORIGIN=""
ADMIN_TOKEN=""
ADMIN_API_KEY=""
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""
ADMIN_PASSWORD_HASH=""
ADMIN_SESSION_MINUTES=480
API_RATE_LIMIT_PER_MINUTE=180
LOGIN_RATE_LIMIT_PER_MINUTE=10
SYNC_RATE_LIMIT_PER_MINUTE=8
CACHE_TTL_SECONDS=45
BACKUP_INTERVAL_MINUTES=120
BACKUPS_DIR="./data/backups"
